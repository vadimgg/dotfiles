term = xterm-256color
theme = Catppuccin Mocha

font-style-bold = "Medium"
font-size = 18
font-thicken = true

cursor-style = "bar"
cursor-style-blink = true
scrollback-limit = 20000
window-padding-x = 15
window-padding-y = 15
window-save-state = "always"

background-opacity = 0.8
background-blur-radius = 25

keybind = ctrl+shift+n=new_tab
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab

keybind = ctrl+shift+l=new_split:right
keybind = ctrl+shift+j=new_split:down

keybind = ctrl+h=goto_split:left
keybind = ctrl+l=goto_split:right
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top

keybind = ctrl+shift+backspace=close_surface

keybind = ctrl+shift+equal=increase_font_size:1
keybind = ctrl+shift+minus=decrease_font_size:1

keybind = ctrl+shift+f=toggle_split_zoom
keybind = ctrl+shift+t=toggle_quick_terminal
keybind = ctrl+shift+;=reload_config

# Define the resize table
keybind = resize/
keybind = resize/h=resize_split:left,20
keybind = resize/l=resize_split:right,20
keybind = resize/j=resize_split:down,20
keybind = resize/k=resize_split:up,20
keybind = resize/equal=equalize_splits
keybind = resize/escape=deactivate_key_table
keybind = resize/catch_all=ignore

# Enter resize mode
keybind = ctrl+r=activate_key_table:resize

quit-after-last-window-closed = true
